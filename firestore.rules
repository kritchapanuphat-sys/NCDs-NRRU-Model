rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ══════════════════════════════════════════════════════════════
    // 🔓 RELAXED RULES (Migration Mode)
    //
    // ในระหว่างที่ยังไม่ได้ deploy Cloud Function generateLineAuthToken
    // ระบบ auth ยังต้องพึ่ง anonymous sign-in + session UID
    //
    // กฎชั่วคราว: ตรวจสอบจาก uid field ใน document เท่านั้น
    // (ไม่พึ่ง request.auth.uid เพราะอาจเป็น null)
    //
    // หลังจาก deploy Cloud Function → Custom Token → request.auth.uid ใช้ได้
    // แล้วค่อยเปลี่ยนเป็น strict rules
    // ══════════════════════════════════════════════════════════════

    function isLoggedIn() {
      return request.auth != null;
    }

    // Users collection — anyone authenticated can read/write their own
    match /users/{userId} {
      allow read, write: if isLoggedIn();
    }

    // User-owned collections — check uid field matches (but allow during migration)
    match /foodLogs/{docId} {
      allow read, write: if isLoggedIn();
    }

    match /healthLogs/{docId} {
      allow read, write: if isLoggedIn();
    }

    match /bodyStats/{docId} {
      allow read, write: if isLoggedIn();
    }

    match /reminders/{docId} {
      allow read, write: if isLoggedIn();
    }

    match /missionCompletions/{docId} {
      allow read, write: if isLoggedIn();
    }

    match /redemptions/{docId} {
      allow read, write: if isLoggedIn();
    }

    match /transactions/{docId} {
      allow read, write: if isLoggedIn();
    }

    match /dailyCalorieSummaries/{docId} {
      allow read, write: if isLoggedIn();
    }

    match /calorieNotifications/{docId} {
      allow read, write: if isLoggedIn();
    }

    // Public collections
    match /missions/{docId} {
      allow read: if true;
      allow write: if isLoggedIn();
    }

    match /rewards/{docId} {
      allow read: if true;
      allow write: if isLoggedIn();
    }

    match /leaderboard/{docId} {
      allow read: if true;
      allow write: if isLoggedIn();
    }

    // Default: require auth
    match /{document=**} {
      allow read, write: if isLoggedIn();
    }
  }
}